# Bloqueia download direto de dados sensíveis (sqlite, planilhas, json, certificados).
# O PHP continua lendo esses arquivos pelo sistema de arquivos; só o acesso HTTP é negado.
<FilesMatch "\.(sqlite|sqlite3|db|xlsx|xls|docx|json|pem|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Bloqueia as pastas de dados/build por completo
RedirectMatch 404 /suprimentos/(data|Bases|tools)/
